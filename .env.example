NODE_ENV=production
PORT=8080
DATABASE_URL=postgres://messenger:messenger@postgres:5432/messenger
JWT_ACCESS_SECRET=change-me-access-secret-at-least-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-32-chars
PUBLIC_URL=http://localhost:8080
UPLOAD_DIR=storage/uploads
MAX_UPLOAD_MB=25
CORS_ORIGIN=http://localhost:8080
WEB_CONCURRENCY=2
RATE_LIMIT_POINTS=600
AUTH_RATE_LIMIT_POINTS=20
WS_RATE_LIMIT_POINTS=120
MAX_WS_PAYLOAD_BYTES=8192
STUN_URL=stun:stun.l.google.com:19302
# TURN_URL=turn:turn.example.com:3478
# TURN_USERNAME=turn-user
# TURN_CREDENTIAL=turn-password

# Desktop Electron embedded gateway
LIQUID_MESSENGER_DESKTOP_PORT=18080
LIQUID_MESSENGER_EMBED_SERVER=true
# LIQUID_MESSENGER_URL=https://messenger.example.com
